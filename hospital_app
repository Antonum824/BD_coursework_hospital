    # Отчеты
    def get_statistics(self):
        cursor = self.conn.cursor()
        cursor.execute("""
            SELECT 
                COUNT(*) as total,
                SUM(CASE WHEN status = 'active' THEN 1 ELSE 0 END) as active,
                SUM(CASE WHEN status = 'discharged' THEN 1 ELSE 0 END) as discharged
            FROM patients
        """)
        return cursor.fetchone()

    def get_patients_by_doctor(self, doctor_id):
        cursor = self.conn.cursor()
        cursor.execute("""
            SELECT p.full_name, p.birth_date, p.hospitalization_date, 
                   d.name as diagnosis_name, p.status
            FROM patients p
            LEFT JOIN diagnoses d ON p.diagnosis_id = d.diagnosis_id
            WHERE p.attending_doctor_id = %s
            ORDER BY p.hospitalization_date DESC
        """, (doctor_id,))
        return cursor.fetchall()

    def get_active_patients_report(self, sort_by="date_desc"):
        cursor = self.conn.cursor()
        order = "p.hospitalization_date DESC"
        if sort_by == "date_asc":
            order = "p.hospitalization_date ASC"
        elif sort_by == "name":
            order = "p.full_name ASC"
        cursor.execute(f"""
            SELECT p.full_name, p.birth_date, p.hospitalization_date, 
                   p.status, doc.full_name as doctor_name
            FROM patients p
            LEFT JOIN doctors doc ON p.attending_doctor_id = doc.doctor_id
            WHERE p.status = 'active'
            ORDER BY {order}
        """)
        return cursor.fetchall()

    def close(self):
        if self.conn:
            self.conn.close()

