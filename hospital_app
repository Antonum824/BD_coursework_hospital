    def show_doctor_report(self):
        if not self.report_doctor_combo.get():
            messagebox.showwarning("Внимание", "Выберите врача")
            return
        did = int(self.report_doctor_combo.get().split(" - ")[0])
        name = self.report_doctor_combo.get().split(" - ")[1]
        patients = self.db.get_patients_by_doctor(did)
        self.report_text.delete(1.0, tk.END)
        self.report_text.insert(tk.END, "=" * 60 + "\n")
        self.report_text.insert(tk.END, f"ОТЧЕТ: Пациенты врача {name}\n")
        self.report_text.insert(tk.END, f"Дата: {datetime.now().strftime('%d.%m.%Y %H:%M:%S')}\n")
        self.report_text.insert(tk.END, "=" * 60 + "\n\n")
        for i, p in enumerate(patients, 1):
            self.report_text.insert(tk.END, f"{i}. {p[0]} - {p[3] if p[3] else 'без диагноза'} ({p[4]})\n")
        self.report_text.insert(tk.END, f"\nИТОГО: {len(patients)} пациентов\n")

    def show_active_report(self):
        sort = self.report_sort_combo.get()
        smap = {"По дате (новые)": "date_desc", "По дате (старые)": "date_asc", "По ФИО": "name"}
        patients = self.db.get_active_patients_report(smap.get(sort, "date_desc"))
        self.report_text.delete(1.0, tk.END)
        self.report_text.insert(tk.END, "=" * 60 + "\n")
        self.report_text.insert(tk.END, "ОТЧЕТ: Активные пациенты\n")
        self.report_text.insert(tk.END, f"Сортировка: {sort}\n")
        self.report_text.insert(tk.END, f"Дата: {datetime.now().strftime('%d.%m.%Y %H:%M:%S')}\n")
        self.report_text.insert(tk.END, "=" * 60 + "\n\n")
        for i, p in enumerate(patients, 1):
            self.report_text.insert(tk.END, f"{i}. {p[0]} - поступил(а): {p[2]}\n")
        self.report_text.insert(tk.END, f"\nИТОГО активных пациентов: {len(patients)}\n")

