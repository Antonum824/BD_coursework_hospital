    def load_patients(self):
        for row in self.patients_tree.get_children():
            self.patients_tree.delete(row)

        # Получаем всех пациентов
        all_patients = self.db.get_patients()

        # Применяем поиск по ФИО (поле 1)
        search_term = self.search_entry.get().strip().lower() if hasattr(self, 'search_entry') else ""
        if search_term:
            all_patients = [p for p in all_patients if search_term in p[1].lower()]

        # Применяем фильтр по статусу (поле 8)
        if hasattr(self, 'status_filter_combo'):
            filter_status = self.status_filter_combo.get()
            if filter_status != "Все":
                all_patients = [p for p in all_patients if p[8] == filter_status]

        # Вставляем в таблицу
        for p in all_patients:
            self.patients_tree.insert("", tk.END, values=p)

        # Обновляем статусную строку, если она есть
        if hasattr(self, 'status_label'):
            filter_text = []
            if search_term:
                filter_text.append(f"поиск: '{search_term}'")
            if hasattr(self, 'status_filter_combo') and self.status_filter_combo.get() != "Все":
                filter_text.append(f"статус: {self.status_filter_combo.get()}")

            if filter_text:
                self.status_label.config(text=f"Загружено: {len(all_patients)} ({', '.join(filter_text)})")
            else:
                self.status_label.config(text=f"Загружено записей: {len(all_patients)}")

