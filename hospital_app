class Database:
    def __init__(self):
        self.conn = None
        self.connect()

    def connect(self):
        try:
            self.conn = psycopg2.connect(
                host="localhost",
                database="hospital",
                user="postgres",
                password="12345",
                port="5432"
            )
            print("Подключение к БД успешно!")
        except Exception as e:
            messagebox.showerror("Ошибка", f"Не удалось подключиться к БД: {e}")

    def rollback(self):
        if self.conn:
            self.conn.rollback()

    # Пациенты
    def get_patients(self):
        cursor = self.conn.cursor()
        cursor.execute("""
            SELECT p.patient_id, p.full_name, p.birth_date, p.gender,
                   p.address, p.phone, d.full_name as doctor_name,
                   di.name as diagnosis_name, p.status
            FROM patients p
            LEFT JOIN doctors d ON p.attending_doctor_id = d.doctor_id
            LEFT JOIN diagnoses di ON p.diagnosis_id = di.diagnosis_id
            ORDER BY p.patient_id
        """)
        return cursor.fetchall()

    def get_patient_by_id(self, patient_id):
        cursor = self.conn.cursor()
        cursor.execute("SELECT * FROM patients WHERE patient_id = %s", (patient_id,))
        return cursor.fetchone()

    def add_patient(self, data):
        cursor = self.conn.cursor()
        try:
            cursor.execute("""
                INSERT INTO patients (full_name, birth_date, gender, address, phone,
                                     hospital_id, department_id, attending_doctor_id, 
                                     diagnosis_id, hospitalization_date)
                VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s)
                RETURNING patient_id
            """, data)
            patient_id = cursor.fetchone()[0]
            self.conn.commit()
            return patient_id
        except Exception as e:
            self.rollback()
            raise e

    def update_patient(self, patient_id, data):
        cursor = self.conn.cursor()
        try:
            cursor.execute("""
                UPDATE patients 
                SET full_name=%s, birth_date=%s, gender=%s, address=%s, phone=%s,
                    attending_doctor_id=%s, diagnosis_id=%s
                WHERE patient_id=%s
            """, (*data, patient_id))
            self.conn.commit()
        except Exception as e:
            self.rollback()
            raise e

    def delete_patient(self, patient_id):
        cursor = self.conn.cursor()
        cursor.execute("DELETE FROM patients WHERE patient_id=%s", (patient_id,))
        self.conn.commit()

    def discharge_patient(self, patient_id):
        cursor = self.conn.cursor()
        cursor.execute("""
            UPDATE patients 
            SET discharge_date = CURRENT_DATE, status = 'discharged' 
            WHERE patient_id=%s
        """, (patient_id,))
        self.conn.commit()

